{
  "name": "rhodonite-mbt",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build:moon": "cd moon/rhodonite_examples && moon build --target js",
    "dev:js:basic-triangle": "pnpm run build:moon && vite --open /demos/basic-triangle.html",
    "dev:js:triangle-with-buffer": "pnpm run build:moon && vite --open /demos/triangle-with-buffer.html",
    "dev:js:depth-test": "pnpm run build:moon && vite --open /demos/depth-test.html",
    "dev:js:ecs-scene-graph": "pnpm run build:moon && vite --open /demos/ecs-scene-graph.html",
    "dev:js:ecs-mass-cubes": "pnpm run build:moon && vite --open /demos/ecs-mass-cubes.html",
    "dev:native:basic-triangle": "bash scripts/run-wgpu-sdl3.sh basic-triangle",
    "dev:native:triangle-with-buffer": "bash scripts/run-wgpu-sdl3.sh triangle-with-buffer",
    "dev:native:depth-test": "bash scripts/run-wgpu-sdl3.sh depth-test",
    "dev:native:ecs-scene-graph": "bash scripts/run-wgpu-sdl3.sh ecs-scene-graph",
    "dev:native:ecs-mass-cubes": "bash scripts/run-wgpu-sdl3.sh ecs-mass-cubes",
    "build": "pnpm run build:moon && tsc && vite build",
    "build:core:js": "cd moon/rhodonite_core && moon build --target js --release",
    "test:core:js": "pnpm run build:core:js && vitest run moon/rhodonite_core/src/math/ts",
    "test:core:mbt": "bash scripts/test-rhodonite-core-mbt.sh",
    "bench:ecs": "bash scripts/run-ecs-bench.sh",
    "bench:ecs:js": "bash scripts/run-ecs-bench.sh js",
    "bench:ecs:native": "bash scripts/run-ecs-bench.sh native",
    "bench:ecs:wasm": "bash scripts/run-ecs-bench.sh wasm-gc",
    "publish:moon": "bash scripts/publish-rhodonite-mooncakes.sh"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@webgpu/types": "^0.1.64",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
