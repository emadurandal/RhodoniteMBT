{
  "name": "webgpu-ex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:moon": "cd moon-examples && moon build --target js",
    "dev:basic-triangle": "npm run build:moon && vite --open /demos/basic-triangle.html",
    "dev:triangle-with-buffer": "npm run build:moon && vite --open /demos/triangle-with-buffer.html",
    "dev": "npm run dev:basic-triangle",
    "run:wgpu:basic-triangle": "bash scripts/run-wgpu-sdl3.sh basic-triangle",
    "run:wgpu:triangle-with-buffer": "bash scripts/run-wgpu-sdl3.sh triangle-with-buffer",
    "run:wgpu": "npm run run:wgpu:basic-triangle",
    "build": "npm run build:moon && tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.64",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
