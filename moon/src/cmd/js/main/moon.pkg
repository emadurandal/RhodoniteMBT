import {
  "emadurandal/WebGPU" @lib,
  "moonbitlang/async/js_async",
}

supported_targets = "js"

options(
  "is-main": true,
  link: { "js": { "exports": [ "create_webgpu_renderer" ], "format": "esm" } },
  overrides: [ "emadurandal/WebGPU/webgpu_objects/js" ],
)
