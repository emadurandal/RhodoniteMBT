import {
  "emadurandal/rhodonite_core/binary/writes" @writes,
  "emadurandal/rhodonite_core/ecs" @ecs,
  "emadurandal/rhodonite_core/ecs/components" @comp,
  "emadurandal/rhodonite_core/math/matrix44" @m44,
  "emadurandal/rhodonite_core/math/vector4" @v4,
  "emadurandal/rhodonite_examples/common/orbit_camera" @orbit,
  "moonbitlang/core/ref" @ref,
}

supported_targets = "+wasm+wasm-gc"

options(
  is_main: true,
  link: {
    "wasm": {
      "exports": [ "create_wasm_demo_state", "ecs_mass_cubes_wasm_render_tick" ],
    },
    "wasm-gc": {
      "exports": [ "create_wasm_demo_state", "ecs_mass_cubes_wasm_render_tick" ],
    },
  },
)
