import {
  "emadurandal/rhodonite/app" @app,
  "emadurandal/rhodonite_app_sdl3/sdl3" @sdl_app,
  "emadurandal/rhodonite_examples/ondemand-triangle/common" @demo_state,
  "moonbitlang/async" @async,
}

supported_targets = "native"

options(
  "is-main": true,
  link: {
    "native": { "cc-link-flags": "-L/opt/homebrew/lib -L/usr/local/lib -lSDL3" },
  },
  overrides: [ "emadurandal/rhodonite_webgpu/webgpu_objects/native" ],
)
