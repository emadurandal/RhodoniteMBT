import {
  "emadurandal/WebGPU-examples/common/browser" @html_ctx,
  "emadurandal/WebGPU-examples/depth-test/common" @renderer,
  "emadurandal/WebGPU/webgpu" @wgpu,
  "moonbitlang/async/js_async",
  "moonbitlang/core/ref" @ref,
}

supported_targets = "js"

options(
  "is-main": true,
  link: {
    "js": {
      "exports": [ "create_webgpu_renderer", "depth_test_render_tick" ],
      "format": "esm",
    },
  },
  overrides: [ "emadurandal/WebGPU/webgpu_objects/js" ],
)
