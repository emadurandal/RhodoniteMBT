import {
  "emadurandal/WebGPU-examples/common" @sdl_wgpu,
  "emadurandal/WebGPU-examples/basic-triangle/common" @renderer,
  "moonbitlang/async" @async,
}

supported_targets = "native"

options(
  "is-main": true,
  link: {
    "native": { "cc-link-flags": "-L/opt/homebrew/lib -L/usr/local/lib -lSDL3" },
  },
  overrides: [ "emadurandal/WebGPU/webgpu_objects/native" ],
)
